# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Managed Postgres connection (enable SSL if required by provider)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Optional HikariCP tuning
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=5
DB_POOL_IDLE_TIMEOUT_MS=

# FFmpeg path (inside container)
APP_FFMPEG_LOCATION=/usr/bin/ffmpeg

# yt-dlp path (inside container). Leave blank for local dev to use auto-discovery
# via COMMON_BIN_DIRS in DefaultProcessExecutor (/opt/homebrew/bin, /usr/local/bin, /usr/bin).
APP_YTDLP_LOCATION=/usr/bin/yt-dlp

# OpenAI API key (used by the application)
OPENAI_API_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRATION_MS=604800000
JWT_REFRESH_EXPIRATION_MS=2592000000

# Google OAuth
GOOGLE_CLIENT_ID=

# Google Play Billing Configuration
GOOGLE_PLAY_PACKAGE_NAME=com.contentcategorise.transcribeassistant
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=/path/to/google-play-service-account.json
GOOGLE_PLAY_PRODUCT_ID_MONTHLY=premium_monthly

# Application Base URL
APP_BASE_URL=http://localhost:8081
