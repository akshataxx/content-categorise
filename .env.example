# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Managed Postgres connection (enable SSL if required by provider)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Optional HikariCP tuning
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=5
DB_POOL_IDLE_TIMEOUT_MS=

# FFmpeg path (inside container)
APP_FFMPEG_LOCATION=/usr/bin/ffmpeg

# OpenAI API key (used by the application)
OPENAI_API_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRATION_MS=604800000
JWT_REFRESH_EXPIRATION_MS=2592000000

# Google OAuth
GOOGLE_CLIENT_ID=

# Logging (override defaults in application.properties)
# LOG_LEVEL_ROOT=INFO
# LOG_FILE_NAME=logs/content-app.log
# LOG_FILE_PATTERN=logs/content-app-%d{yyyy-MM-dd}.%i.log.gz
# LOG_MAX_FILE_SIZE=10MB
# LOG_MAX_HISTORY=7
# LOG_TOTAL_SIZE_CAP=1GB